5.  Apresente as estatísticas descritivas das questões 3 e 4 em gráficos

```{r}

# Imagem corporal por sexo

bsq_eat %>%
  drop_na(bsq_soma,sexo) %>% 
  ggplot() + 
  geom_point(aes(x=sexo,
                 y=bsq_soma),
             stat = "summary",
             fun = "mean") + 
  geom_errorbar(aes(x=sexo,
                    y=bsq_soma),
                stat = "summary",
                fun.data = "mean_se",
                width = 0.3) + 
  coord_cartesian(ylim = c(50,90)) +
  labs(title = "Imagem Corporal por Sexo",
       x = "Sexo",
       y = "Imagem Corporal")

# Transtornos alimentares por sexo
bsq_eat %>%
  drop_na(bsq_soma,sexo) %>% 
  ggplot() + 
  geom_point(aes(x=sexo,
                 y=eat_soma),
             stat = "summary",
             fun = "mean") + 
  geom_errorbar(aes(x=sexo,
                    y=eat_soma),
                stat = "summary",
                fun.data = "mean_se",
                width = 0.3) + 
  coord_cartesian(ylim = c(7,13)) +
# Título e rótulos dos eixos
  labs(title = "Transtornos Alimentares por Sexo",
       x = "Sexo",
       y = "Transtornos Alimentares")

# tendência ao empreendedorismo por escolaridade
teg %>% 
  drop_na(teg,escolaridade) %>% 
  ggplot() +
  geom_point(aes(x=escolaridade,
                 y=teg),
             stat = "summary",
             fun = "mean") + 
  geom_errorbar(aes(x=escolaridade,
                    y=teg),
                stat = "summary",
                fun.data = "mean_se",
                width = 0.3) + 
  coord_cartesian(ylim = c(22,33)) + 
  labs(title = "Tendência ao Empreendedorismo por Escolaridade",
       x = "Escolaridade",
       y = "Tendência ao Empreendedorismo")
```



